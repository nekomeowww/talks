{
  "name": "velin",
  "scopeName": "source.velin",
  "fileTypes": ["velin.md"],
  "aliases": ["velin-md"],
  "patterns": [
    { "include": "#script-block" },
    { "include": "#template" }
  ],
  "repository": {
    "template": {
      "patterns": [
        { "include": "#comment" },
        { "include": "#template-tag" },
        { "include": "#component-tag" },
        { "include": "#html-tag" },
        { "include": "#interpolation" },
        { "include": "#md-heading" },
        { "include": "#md-bold" }
      ]
    },
    "script-block": {
      "begin": "(<)(script)\\b([^>]*)(>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.html" },
        "2": { "name": "entity.name.tag.script.html" },
        "3": { "patterns": [{ "include": "#tag-attributes" }] },
        "4": { "name": "punctuation.definition.tag.end.html" }
      },
      "end": "(</)(script)(>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.html" },
        "2": { "name": "entity.name.tag.script.html" },
        "3": { "name": "punctuation.definition.tag.end.html" }
      },
      "contentName": "meta.embedded.block.typescript",
      "patterns": [{ "include": "source.ts" }]
    },
    "comment": {
      "begin": "<!--",
      "end": "-->",
      "name": "comment.block.html"
    },
    "template-tag": {
      "begin": "(</?)(template)\\b",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.html" },
        "2": { "name": "entity.name.tag.template.html" }
      },
      "end": "(/?>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.end.html" }
      },
      "patterns": [{ "include": "#tag-attributes" }]
    },
    "component-tag": {
      "begin": "(</?)([A-Z][-\\w]*)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.html" },
        "2": { "name": "support.class.component.velin" }
      },
      "end": "(/?>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.end.html" }
      },
      "patterns": [{ "include": "#tag-attributes" }]
    },
    "html-tag": {
      "begin": "(</?)([a-z][-\\w]*)(?=[\\s/>])",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.html" },
        "2": { "name": "entity.name.tag.html" }
      },
      "end": "(/?>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.end.html" }
      },
      "patterns": [{ "include": "#tag-attributes" }]
    },
    "tag-attributes": {
      "patterns": [
        {
          "begin": "((?:v-[\\w-]+(?::[\\w-]+)?)|(?:[:@#][\\w-]+))(=)(\")",
          "beginCaptures": {
            "1": { "name": "keyword.control.directive.velin" },
            "2": { "name": "punctuation.separator.key-value.html" },
            "3": { "name": "punctuation.definition.string.begin.html" }
          },
          "end": "\"",
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.html" }
          },
          "contentName": "meta.embedded.expression.typescript",
          "patterns": [{ "include": "source.ts" }]
        },
        {
          "match": "(?:v-[\\w-]+(?::[\\w-]+)?)|(?:[:@#][\\w-]+)",
          "name": "keyword.control.directive.velin"
        },
        {
          "begin": "([\\w-]+)(=)(\")",
          "beginCaptures": {
            "1": { "name": "entity.other.attribute-name.html" },
            "2": { "name": "punctuation.separator.key-value.html" },
            "3": { "name": "punctuation.definition.string.begin.html" }
          },
          "end": "\"",
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.html" }
          },
          "name": "string.quoted.double.html"
        },
        {
          "match": "[\\w-]+",
          "name": "entity.other.attribute-name.html"
        }
      ]
    },
    "interpolation": {
      "begin": "\\{\\{",
      "end": "\\}\\}",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.interpolation.begin.velin" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.interpolation.end.velin" }
      },
      "contentName": "meta.embedded.expression.typescript",
      "patterns": [
        {
          "match": "\\b[$A-Za-z_][$\\w]*(?:\\.[$A-Za-z_][$\\w]*)*",
          "name": "variable.parameter.ts"
        },
        { "include": "source.ts" }
      ]
    },
    "md-heading": {
      "match": "^#{1,6}\\s.*$",
      "name": "markup.heading.markdown"
    },
    "md-bold": {
      "match": "\\*\\*[^*]+\\*\\*",
      "name": "markup.bold.markdown"
    }
  }
}
